	//maxmimum number
	public void maxmin()
	{
		int array[] = {30,100,50,20,5,200};
		
		int max = array[0];
		
		for(int i=0;i<array.length;i++)
		{
			if(array[i] > max)
			{
				max = array[i];
			}
		}
		System.out.println("Max Element in array:" + max);
	
		int min = array[0];
		for(int i=0; i<array.length;i++)
		{
			if(array[i] < min)
			{
				min = array[i];
			}
		}
		System.out.println("Min Element in array:" +min);
	}
	
	//@Test
	public void lowerupperAlph()
	{
		String ab = "WelCome to AuTomaTiON";
		
		int upperCount = 0;
		int lowerCount = 0;
		
		for(int i=0; i<ab.length();i++)
		{
			char ch = ab.charAt(i);
			
			if(Character.isUpperCase(ch))
			{
				upperCount++;
			}
			else if(Character.isLowerCase(ch))
			{
				lowerCount++;
			}
		}
		System.out.println("Upper count character:" +upperCount);
		System.out.println("Lower count character:" +lowerCount);
	}
	
	@Test
	public void dragAndDrop()
	{
		String input = "Kunal Shah is in Vadodara";

        String[] words = input.split(" ");
        StringBuilder result = new StringBuilder();

        // Take only first character of first 2 words
        for (int i = 0; i < words.length; i++) 
        {
        	if(i<2)
        	{
        		result.append(words[i].charAt(0)).append(" ");
        	}
        	else
        	{
        		result.append(words[i]).append(" ");
        	}
        }

        // Trim last extra space
        System.out.println(result.toString().trim());
    }
	
